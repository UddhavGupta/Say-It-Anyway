# =============================================================================
# Say It Anyway — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# API Server (artifacts/api-server)
# Required for the backend to start.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Local example:  postgresql://user:password@localhost:5432/sayitanyway
# Supabase/Neon:  find this in your project's connection settings.
DATABASE_URL=postgresql://user:password@localhost:5432/sayitanyway

# Express session secret — use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the API server listens on (default: 8080)
PORT=8080

# ---------------------------------------------------------------------------
# Frontend dev server (artifacts/say-it-anyway)
# Only needed when running locally via `pnpm --filter @workspace/say-it-anyway run dev`.
# Cloudflare Pages / Vercel build pipelines do NOT need these.
# ---------------------------------------------------------------------------

# Port the Vite dev server listens on (default: 5173)
# PORT=5173

# URL base path — leave as "/" unless the app is served from a sub-path
# BASE_PATH=/

# ---------------------------------------------------------------------------
# Frontend build — API base URL
# Set this if your API server is not at the same origin as the frontend.
# Used by the React Query client to prepend to every API request URL.
# Example: https://api.yourdomain.com
# ---------------------------------------------------------------------------
# VITE_API_BASE_URL=
